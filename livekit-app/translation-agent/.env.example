# Translation Agent — environment variables
# Copy to .env and fill in real values.

# LiveKit credentials
LIVEKIT_URL=wss://your-server.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
AGENT_NAME=translation-cloud-prod

# STT provider: xai | deepgram | openai
STT_PROVIDER=deepgram
XAI_API_KEY=
DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# LLM provider for translation: xai | openai
LLM_PROVIDER=openai
XAI_LLM_MODEL=grok-4.20-non-reasoning

# Cost event reporting (Phase 1.5)
# Must match COST_EVENT_SECRET in backend/.env
BACKEND_BASE_URL=http://localhost:3001
COST_EVENT_SECRET=replace-with-32-byte-hex

# Optional tuning
VAD_ACTIVATION_THRESHOLD=0.4
XAI_STT_ENDPOINTING_MS=1000
LIVEKIT_CLOUD=false
