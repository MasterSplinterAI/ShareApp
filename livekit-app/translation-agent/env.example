# LiveKit Configuration
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here
LIVEKIT_URL=wss://your-project.livekit.cloud

# STT Provider (Deepgram)
DEEPGRAM_API_KEY=your_deepgram_key_here
# Optional: comma-separated keyterms (minerals, metals trading, finance, tech)
# Default covers: minerals (Cassiterite, Chalcopyrite...), metals (PGM, LME...),
# trading (Backwardation, Assay...), finance (KYC, AML...), tech (SaaS, API...)
# DEEPGRAM_KEYTERMS=term1,term2,...

# Translation (Google Cloud)
# Download service account JSON and set path
GOOGLE_APPLICATION_CREDENTIALS=path/to/google-cloud-key.json

# TTS Provider (ElevenLabs)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Agent Configuration
AGENT_NAME=translation-bot
LOG_LEVEL=INFO

# Optional: OpenAI for fallback
OPENAI_API_KEY=your_openai_key_here
