# Local Development Configuration
# Copy this to .env for local development

# LiveKit Configuration (can point to cloud for testing, but agent name must be local)
LIVEKIT_URL=wss://production-uiycx4ku.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5174
NETWORK_URL=http://192.168.1.83:5174

# V2 SaaS
JWT_SECRET_V2=change-me-to-a-long-random-string
# Comma-separated emails allowed to use /v2/app/superadmin (GET /api/v2/orgs/admin/*). Case-insensitive.
# Example: V2_SUPERADMIN_EMAILS=kenny@jarmetals.com,ops@example.com
# V2_SUPERADMIN_EMAILS=
# V2_DB_PATH=/absolute/path/to/v2-platform.db
# V2_AUTO_CHARGE_ENABLED=false

# LOCAL AGENT NAME (different from cloud)
AGENT_NAME=translation-bot-dev
