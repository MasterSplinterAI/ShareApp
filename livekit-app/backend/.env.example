# LiveKit Backend — environment variables
# Copy to .env and fill in real values.

# LiveKit credentials
LIVEKIT_URL=wss://your-server.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# JWT
JWT_SECRET_V2=replace-with-long-random-string

# Translation API
TRANSLATION_API_KEY=replace-with-api-key
TRANSLATION_API_PROVIDER=grok
TRANSLATION_API_URL=https://api.x.ai/v1/chat/completions
TRANSLATION_MODEL=grok-4.20-non-reasoning

# Database
USE_DATABASE_CACHE=false
V2_DB_PATH=

# Stripe
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace

# URLs
FRONTEND_URL=http://localhost:5174
NETWORK_URL=http://localhost:5174
BACKEND_BASE_URL=http://localhost:3001
STAGING_FRONTEND_URL=

# Phase 1: Cost tracking + webhooks
LIVEKIT_WEBHOOK_VERIFY=true
COST_EVENT_SECRET=replace-with-32-byte-hex
